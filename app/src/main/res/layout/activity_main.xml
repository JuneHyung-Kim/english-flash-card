<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="32dp"
    android:background="@color/background">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/home_title"
        android:textSize="40sp"
        android:textStyle="bold"
        android:textColor="@color/textPrimary"
        android:layout_marginBottom="12dp" />

    <TextView
        android:id="@+id/cardCountText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="16sp"
        android:textColor="@color/textHint"
        android:layout_marginBottom="60dp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/startButton"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="전체 학습"
        android:textSize="17sp"
        android:textStyle="bold"
        android:textAllCaps="false"
        android:textColor="#FFFFFF"
        app:cornerRadius="30dp"
        app:backgroundTint="@color/buttonPrimary" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/bookmarkedButton"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="12dp"
        android:textSize="15sp"
        android:textAllCaps="false"
        android:textColor="#FFFFFF"
        app:cornerRadius="28dp"
        app:backgroundTint="@color/buttonSecondary"
        android:visibility="gone" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/userCardsButton"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="12dp"
        android:textSize="15sp"
        android:textAllCaps="false"
        android:textColor="#FFFFFF"
        app:cornerRadius="28dp"
        app:backgroundTint="@color/buttonPrimary"
        android:visibility="gone" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/addCardButton"
        style="@style/Widget.MaterialComponents.Button.TextButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:text="+ 카드 추가"
        android:textSize="15sp"
        android:textAllCaps="false"
        android:textColor="@color/textHint" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/excludedManageButton"
        style="@style/Widget.MaterialComponents.Button.TextButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:textSize="13sp"
        android:textAllCaps="false"
        android:textColor="@color/excludeActive"
        android:visibility="gone" />

</LinearLayout>
